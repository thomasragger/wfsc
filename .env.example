# --- Supabase (project settings → API) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- AI providers ---
ANTHROPIC_API_KEY=
REPLICATE_API_TOKEN=
# Optional model overrides
# WFSC_STORY_MODEL=claude-sonnet-5
# WFSC_QA_MODEL=claude-sonnet-5
# WFSC_MODEL_CHARACTER=google/nano-banana-pro
# WFSC_MODEL_SPREAD=bytedance/seedream-4.5
# WFSC_MODEL_UPSCALE=recraft-ai/recraft-crisp-upscale

# --- Inngest (auto-configured on Vercel integration; blank for local dev) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Shopify (single-store custom app, created in Dev Dashboard) ---
SHOPIFY_SHOP_DOMAIN=            # e.g. warm-fuzzy-story-club.myshopify.com
SHOPIFY_CLIENT_ID=              # Dev Dashboard -> WFSC Studio -> Client credentials
SHOPIFY_CLIENT_SECRET=          # Dev Dashboard -> WFSC Studio -> Client credentials
SHOPIFY_STOREFRONT_TOKEN=       # created via API once client credentials work (leave empty)
# Optional overrides (not needed for Dev Dashboard apps):
# SHOPIFY_ADMIN_TOKEN=          # static admin token (legacy admin-created apps only)
# SHOPIFY_WEBHOOK_SECRET=       # defaults to SHOPIFY_CLIENT_SECRET
SHOPIFY_VARIANT_BOARD=          # gid://shopify/ProductVariant/... (scripts/shopify-board-and-image.mjs)
SHOPIFY_VARIANT_SOFTCOVER=      # gid://shopify/ProductVariant/...
SHOPIFY_VARIANT_HARDCOVER=      # gid://shopify/ProductVariant/...
# Customer accounts (optional; account UI stays hidden until both are set)
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=
SHOPIFY_CUSTOMER_ACCOUNT_SHOP_ID=

# --- Lulu Print API ---
LULU_ENV=sandbox                # sandbox | production
LULU_CLIENT_KEY=
LULU_CLIENT_SECRET=
LULU_CONTACT_EMAIL=
# LULU_SKU_HARDCOVER=0850X0850.FC.PRE.CW.080CW444.MXX
# LULU_SKU_SOFTCOVER=0850X0850.FC.PRE.PB.080CW444.MXX

# --- CLI harness ---
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# --- Email (Resend) + Studio URL ---
RESEND_API_KEY=                 # resend.com -> API keys (emails log to console if unset)
EMAIL_FROM=Warm Fuzzy Story Club <hello@warmfuzzystoryclub.com>
STUDIO_URL=https://wfsc-studio.vercel.app

# --- Ops & privacy ---
OPS_ALERT_EMAIL=                # where ops alerts go (stranded orders, GDPR requests)
RETENTION_DAYS=30               # days after shipped/cancelled before source photos are purged

# --- Cost controls (estimates; see apps/studio/src/lib/generation-jobs.ts) ---
PREVIEW_DAILY_BUDGET_USD=50     # pause new free previews past this estimated daily spend (0 = off)
WFSC_MAX_REGENS_PER_BOOK=15     # lifetime spread-redraw cap per book (0 = off)
# WFSC_COST_STORY=0.10          # per-stage estimate overrides
# WFSC_COST_CHARACTER=0.15
# WFSC_COST_SPREAD=0.06
# WFSC_COST_UPSCALE=0.02

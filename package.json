{
  "name": "wfsc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter studio dev",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "generate-book": "pnpm --filter @wfsc/pipeline generate-book",
    "wfsc-admin": "pnpm --filter @wfsc/admin-cli run wfsc-admin"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@shopify/cli": "^4.4.0"
  }
}

{% comment %}
  WFSC Studio CTA — links the storefront to the book builder.
  Add via theme editor: Add section → "Create your book (Studio)".
{% endcomment %}

<div class="wfsc-studio-cta" style="background: linear-gradient(120deg, #f6e7f5 0%, #fdf6e3 45%, #fbd9a0 100%); border-radius: 24px; margin: {{ section.settings.margin_y }}px auto; max-width: 1100px; padding: 56px 32px; text-align: center;">
  <h2 style="font-size: 2.2rem; margin: 0 0 12px; color: #2b2320;">{{ section.settings.heading }}</h2>
  <p style="font-size: 1.15rem; color: #5b4f49; max-width: 560px; margin: 0 auto 28px;">{{ section.settings.subheading }}</p>
  <a href="{{ section.settings.studio_url }}{% if section.settings.template_handle != blank %}?template={{ section.settings.template_handle }}{% endif %}"
     style="display: inline-block; background: #e8622c; color: #fffdf8; font-weight: 700; font-size: 1.1rem; padding: 16px 36px; border-radius: 999px; text-decoration: none; box-shadow: 0 6px 18px rgba(232, 98, 44, 0.35);">
    {{ section.settings.button_label }}
  </a>
</div>

{% schema %}
{
  "name": "Create your book (Studio)",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Turn your memory into a storybook" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Upload your photos, tell us your story, and watch the magic happen — a one-of-a-kind illustrated book, printed and delivered." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Create your book" },
    { "type": "text", "id": "studio_url", "label": "Studio URL", "info": "The book builder", "default": "https://wfsc-studio.vercel.app/create" },
    { "type": "text", "id": "template_handle", "label": "Preselect template (optional)", "info": "e.g. day-at-the-zoo" },
    { "type": "range", "id": "margin_y", "label": "Vertical margin", "min": 0, "max": 120, "step": 8, "default": 48 }
  ],
  "presets": [{ "name": "Create your book (Studio)" }]
}
{% endschema %}
